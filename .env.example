# ============================================================================
# GPS TRACKER - DEPLOYMENT CONFIGURATION TEMPLATE
# ============================================================================
# Este archivo es un template. Para usar:
#   cp .env.example .env
#   nano .env   (edita con tus valores)
#
# NUNCA commites .env a Git (está en .gitignore por seguridad)
# ============================================================================

# ============================================================================
# DEPLOY MODE
# ============================================================================
# Opciones: local | cloudflare | ngrok | production
DEPLOY_MODE=local
API_DOMAIN=localhost
API_PORT=3000

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
POSTGRES_DB=tracking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================================================
# CACHE (Redis)
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================================
# AUTHENTICATION (JWT)
# ============================================================================
JWT_SECRET=change-me-secure-secret-key-min-32-chars
JWT_EXPIRATION=30d

# ============================================================================
# SERVER
# ============================================================================
NODE_ENV=development
SOCKET_PORT=3001
